# Indexer backend URL (required)
VITE_INDEXER_URL=http://localhost:3000

# Stellar network: testnet or mainnet (required, default: testnet)
VITE_STELLAR_NETWORK=testnet

# Set to "true" to use mock API (no backend needed)
VITE_API_MOCK=false

# VAPID public key for push notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=
