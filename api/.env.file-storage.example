# File Storage Service Configuration
# Copy to .env.local in the api/ directory

# ============================================================================
# AWS S3 CONFIGURATION
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
S3_BUCKET_NAME=stellar-escrow-storage

# ============================================================================
# FILE STORAGE SETTINGS
# ============================================================================

# Maximum file sizes (bytes)
IMAGE_MAX_SIZE=5242880        # 5MB
DOCUMENT_MAX_SIZE=10485760    # 10MB

# Allowed MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf

# Image compression settings
IMAGE_QUALITY=80              # WebP quality (0-100)
IMAGE_WIDTH=400               # Avatar width (px)
IMAGE_HEIGHT=400              # Avatar height (px)

# File expiration (seconds)
AVATAR_EXPIRATION=0           # Never expire
DOCUMENT_EXPIRATION=604800    # 7 days

# Signed URL expiration (seconds)
SIGNED_URL_EXPIRATION=86400   # 24 hours

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Enable encryption (AES256)
ENABLE_ENCRYPTION=true

# Enable versioning for disaster recovery
ENABLE_VERSIONING=true

# Block public access
BLOCK_PUBLIC_ACCESS=true

# Enable file scanning (via ClamAV or similar)
ENABLE_VIRUS_SCAN=false
VIRUS_SCAN_ENDPOINT=http://clamav:3310

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=info
ENABLE_AUDIT_LOG=true

# Sentry for error tracking
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# ============================================================================
# RATE LIMITING
# ============================================================================

# Upload rate limits per user
UPLOAD_RATE_LIMIT_PER_HOUR=100    # Max 100 uploads/hour
DOWNLOAD_RATE_LIMIT_PER_MINUTE=30 # Max 30 downloads/minute

# ============================================================================
# CLEANUP & MAINTENANCE
# ============================================================================

# Enable automatic cleanup of expired files
ENABLE_AUTO_CLEANUP=true
CLEANUP_INTERVAL_HOURS=24

# Backup configuration
ENABLE_BACKUP=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
