{
  "name": "@stellar-escrow/api",
  "version": "1.0.0",
  "description": "API integration layer for StellarEscrow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "gateway": "node -r ts-node/register src/gateway/server.ts",
    "test": "jest --runInBand",
    "test:gateway": "jest --config jest.gateway.config.js --runInBand",
    "test:unit": "jest --runInBand unit",
    "test:endpoints": "jest --runInBand endpoint",
    "test:integration": "jest --runInBand integration",
    "test:contract": "jest --runInBand contract",
    "test:load": "jest --runInBand load",
    "test:stress": "jest --runInBand stress",
    "test:benchmark": "jest --runInBand benchmark",
    "test:scalability": "jest --runInBand scalability",
    "test:monitoring": "jest --runInBand monitoring",
    "test:performance": "jest --runInBand --testPathPattern=api.*.test.ts --testNamePattern=\"(load|stress|benchmark|scalability|monitoring)\"",
    "test:docs": "jest --runInBand documentation",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "dev": "ts-node-dev src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "msw": "^1.3.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.10",
    "@types/node": "^22.19.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
